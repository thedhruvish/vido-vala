{
  "name": "vido-vala",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "check-types": "nx run-many -t check-types",
    "dev:web": "nx run-many -t dev --projects=web",
    "dev:server": "nx run-many -t dev --projects=server",
    "db:push": "nx run-many -t db:push --projects=@vido-vala/db",
    "db:studio": "nx run-many -t db:studio --projects=@vido-vala/db",
    "db:generate": "nx run-many -t db:generate --projects=@vido-vala/db",
    "db:migrate": "nx run-many -t db:migrate --projects=@vido-vala/db",
    "test": "nx run server:test",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@vido-vala/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@vido-vala/config": "workspace:*",
    "lefthook": "^2.0.13",
    "nx": "^21.5.2",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.3"
}
