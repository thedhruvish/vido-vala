{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "test": "NODE_ENV=test bun test"
  },
  "dependencies": {
    "@vido-vala/db": "workspace:*",
    "@vido-vala/env": "workspace:*",
    "@vido-vala/validators": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "google-auth-library": "^10.6.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/supertest": "^7.2.0",
    "@vido-vala/config": "workspace:*",
    "supertest": "^7.2.2",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
